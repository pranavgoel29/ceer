{
  "name": "@ceer/monorepo",
  "license": "MIT",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": ["apps/*", "packages/*"]
  },
  "engines": {
    "node": ">=22.18.0",
    "bun": ">=1.2.0"
  },
  "scripts": {
    "postinstall": "bun scripts/ensure-electron.ts",
    "dev": "bun scripts/dev.ts",
    "dev:web": "turbo run dev --filter=@ceer/web",
    "dev:desktop": "bun scripts/dev.ts desktop",
    "stop": "bun run --cwd apps/desktop stop",
    "build": "turbo run build",
    "dist:prepare": "bun run --cwd apps/desktop dist:prepare",
    "dist:mac": "turbo run build --filter=@ceer/web --filter=@ceer/desktop && bun run --cwd apps/desktop dist:mac",
    "dist:win": "turbo run build --filter=@ceer/web --filter=@ceer/desktop && bun run --cwd apps/desktop dist:win",
    "dist:desktop:artifact": "bun scripts/build-desktop-artifact.ts",
    "dist:desktop:dmg": "bun scripts/build-desktop-artifact.ts --platform mac --target dmg",
    "dist:desktop:dmg:arm64": "bun scripts/build-desktop-artifact.ts --platform mac --target dmg --arch arm64",
    "dist:desktop:dmg:x64": "bun scripts/build-desktop-artifact.ts --platform mac --target dmg --arch x64",
    "dist:desktop:win": "bun scripts/build-desktop-artifact.ts --platform win --target nsis",
    "dist:desktop:win:x64": "bun scripts/build-desktop-artifact.ts --platform win --target nsis --arch x64",
    "typecheck": "tsc --noEmit",
    "setup:electron": "bun scripts/ensure-electron.ts",
    "generate:icons": "bun scripts/generate-icons.ts"
  },
  "trustedDependencies": ["electron"],
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.15.0",
    "bun-types": "^1.3.14",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "bun@1.2.19",
  "browserslist": [
    "chrome >= 111",
    "edge >= 111",
    "firefox >= 113",
    "safari >= 16.2"
  ]
}
