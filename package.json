{
  "name": "@ceer/monorepo",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": ["apps/*", "packages/*"]
  },
  "scripts": {
    "postinstall": "node scripts/ensure-electron.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:web": "turbo run dev --filter=@ceer/web",
    "dev:desktop": "node scripts/dev.mjs desktop",
    "dev:kill": "bun run --cwd apps/desktop dev:kill",
    "build": "turbo run build",
    "dist:mac": "turbo run build --filter=@ceer/web --filter=@ceer/desktop && bun run --cwd apps/desktop dist:mac",
    "dist:win": "turbo run build --filter=@ceer/web --filter=@ceer/desktop && bun run --cwd apps/desktop dist:win",
    "typecheck": "turbo run typecheck",
    "setup:electron": "node scripts/ensure-electron.mjs",
    "generate:icons": "node scripts/generate-icons.mjs"
  },
  "trustedDependencies": ["electron"],
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "bun@1.2.19",
  "browserslist": [
    "chrome >= 111",
    "edge >= 111",
    "firefox >= 113",
    "safari >= 16.2"
  ]
}
